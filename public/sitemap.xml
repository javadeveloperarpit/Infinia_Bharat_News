import fs from "fs";
import path from "path";
import { db } from "./firebase"; // Your Firestore instance

async function generateSitemap() {
  try {
    const base = "https://infinia-bharat-news.vercel.app";

    // Fetch all articles and videos
    const [articlesSnap, videosSnap] = await Promise.all([
      db.collection("articles").get(),
      db.collection("videos").get()
    ]);

    // Generate URL entries, trimmed to remove unwanted spaces
    const staticUrls = `<url>
  <loc>${base}</loc>
  <changefreq>hourly</changefreq>
  <priority>1.0</priority>
</url>`;

    const articleUrls = articlesSnap.docs.map(doc => `<url>
  <loc>${base}/article/${doc.id}</loc>
  <changefreq>daily</changefreq>
  <priority>0.9</priority>
</url>`).join("");

    const videoUrls = videosSnap.docs.map(doc => `<url>
  <loc>${base}/video/${doc.id}</loc>
  <changefreq>daily</changefreq>
  <priority>0.8</priority>
</url>`).join("");

    // Build final XML without extra spaces or newlines before <?xml
    const xml = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${staticUrls}
${articleUrls}
${videoUrls}
</urlset>`;

    // Save to public folder
    const filePath = path.join(process.cwd(), "public", "sitemap.xml");
    fs.writeFileSync(filePath, xml, "utf8");

    console.log("✅ Sitemap generated at:", filePath);
  } catch (error) {
    console.error("❌ Error generating sitemap:", error);
  }
}

// Run it once or call after adding new content
generateSitemap();
